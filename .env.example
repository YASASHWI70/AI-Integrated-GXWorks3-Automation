# ============================================================
# GX Works3 Path
# ============================================================
# Set this to the full path of GXW3.exe on your machine.
# Common locations:
#   C:\Program Files (x86)\MELSOFT\GXW3\GXW3.exe
#   C:\Program Files\MELSOFT\GXW3\GXW3.exe
GXW3_EXE_PATH=C:\Program Files (x86)\MELSOFT\GXW3\GXW3.exe

# Default folder where PLC projects will be saved
DEFAULT_PROJECT_PATH=C:\plc_ai_automation\projects

# ============================================================
# AI / LLM Provider  — Anthropic Claude
# ============================================================
# Get your API key at: https://console.anthropic.com/
LLM_PROVIDER=anthropic

# Your Anthropic API key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model to use
ANTHROPIC_MODEL=claude-opus-4-5

# Use "mock" to run without an API key (offline development/testing):
#   LLM_PROVIDER=mock

# ============================================================
# OCR
# ============================================================
# Path to Tesseract OCR executable
# Download from: https://github.com/UB-Mannheim/tesseract/wiki
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# ============================================================
# Automation Behavior
# ============================================================
# Set to "true" to slow down automation and show visual feedback
DEBUG_AUTOMATION=false

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
